# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Astra DB (required) ---
# DataStax Astra DB vector database
ASTRA_DB_ENDPOINT=https://your-db-id.apps.astra.datastax.com
ASTRA_DB_TOKEN=AstraCS:your-token-here

# --- IBM Cloud (required) ---
# Single API key used for IAM auth to all IBM services
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key

# --- watsonx Orchestrate (required) ---
# Agent config — get these from the wxO console
WXO_URL=https://api.eu-de.watson-orchestrate.cloud.ibm.com # should be ait
WXO_AGENT_ID=your-agent-uuid
WXO_ENV_ID=your-environment-uuid
WXO_INSTANCE_ID=your-instance-uuid

# --- Jira Service Management (optional — set all four to enable) ---
JIRA_BASE_URL=https://ruagdesk.atlassian.net # should ait
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SUP
